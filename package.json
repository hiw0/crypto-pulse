{
  "name": "crypto-pulse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "cd server && npx tsx watch src/index.ts",
    "build": "vite build",
    "test": "node --import tsx --test src/**/*.test.ts src/**/*.test.tsx",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vite": "^6.0.0"
  }
}
